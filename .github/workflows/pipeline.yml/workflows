name: CU Medical Tool — CI/CD Pipeline

on:
  push:
    branches:
      - main
      - dev
  pull_request:
    branches:
      - main

jobs:

  lint:
    name: "Stage 1 — Code Quality Check"
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python 3.11
        uses: actions/setup-python@v4
        with:
          python-version: '3.11'

      - name: Install pyflakes
        run: pip install pyflakes

      - name: Run code quality check
        run: |
          echo "Running pyflakes on all Python files..."
          python -m pyflakes csv_validator.py
          python -m pyflakes ftp_client.py
          python -m pyflakes logger.py
          python -m pyflakes cli.py
          python -m pyflakes main.py
          python -m pyflakes generate_test_data.py
          python -m pyflakes demo_api.py
          echo "All files passed code quality check"

  test:
    name: "Stage 2 — Automated Test Suite"
    runs-on: ubuntu-latest
    needs: lint

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python 3.11
        uses: actions/setup-python@v4
        with:
          python-version: '3.11'

      - name: Run CSV validator tests
        run: python -m unittest test_csv_validator -v

      - name: Run Singleton pattern tests
        run: python -m unittest test_singleton -v

      - name: Run complete test suite
        run: python -m unittest discover -v

  build:
    name: "Stage 3 — Docker Image Build"
    runs-on: ubuntu-latest
    needs: test

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Build Docker image
        run: docker build -t cu_medical_tool:latest .

      - name: Verify Docker image
        run: docker images cu_medical_tool

  verify:
    name: "Stage 4 — Container Integration Verification"
    runs-on: ubuntu-latest
    needs: build

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Build Docker image for testing
        run: docker build -t cu_medical_tool:test .

      - name: Run tests inside Docker container
        run: |
          docker run --rm cu_medical_tool:test \
            python -m unittest discover -v

      - name: Run automation script inside container
        run: |
          docker run --rm cu_medical_tool:test \
            python generate_test_data.py

      - name: Pipeline complete
        run: |
          echo "================================================"
          echo "  CI/CD PIPELINE COMPLETE — ALL STAGES PASSED"
          echo "================================================"
          echo "  Stage 1: Code Quality Check    PASSED"
          echo "  Stage 2: Automated Test Suite  PASSED"
          echo "  Stage 3: Docker Image Build    PASSED"
          echo "  Stage 4: Integration Verify    PASSED"
          echo "================================================"